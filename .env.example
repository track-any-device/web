# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://track-any-device.com

# ── GraphQL ───────────────────────────────────────────────────────────
GRAPHQL_URL=https://graphql.track-any-device.com/graphql
GRAPHQL_KEY=
GRAPHQL_SECRET=

# ── SSO / OAuth 2.0 ───────────────────────────────────────────────────
SSO_CLIENT_ID=your-sso-client-id
SSO_CLIENT_SECRET=your-sso-client-secret
SSO_REDIRECT_URI=https://track-any-device.com/sso/callback

SSO_AUTH_URL=https://login.track-any-device.com/oauth/authorize
SSO_TOKEN_URL=https://login.track-any-device.com/oauth/token
SSO_USERINFO_URL=https://login.track-any-device.com/oauth/userinfo

# ── My Portal — REST API (app/) ───────────────────────────────────────
# The "my" portal calls the central app/ REST API with the user's Passport
# bearer token. Set this to your app/ deployment URL.
API_URL=https://api.track-any-device.com

# ── Pusher / Soketi — real-time broadcasting ──────────────────────────
# Server-side (channel auth + webhook verification)
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_SECRET=your-pusher-app-secret

# Client-side (embedded in browser JS — use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-app-key
NEXT_PUBLIC_PUSHER_HOST=ws.track-any-device.com   # public hostname of your Soketi instance
NEXT_PUBLIC_PUSHER_PORT=443                        # 443 via Cloudflare Tunnel, 6001 for direct
NEXT_PUBLIC_PUSHER_SCHEME=https                    # https via Tunnel, http for direct
NEXT_PUBLIC_PUSHER_CLUSTER=mt1
